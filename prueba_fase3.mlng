# Prueba base para Fase 3 (lexico + sintactico + semantico)

func suma(int x, int y):
    int r
    r = x + y
    return r

int a
int b
int c
bool bandera
string texto

a = 10
b = 5
suma(a, b)
c = a + b

bandera = a > b
if bandera:
    write(c)
else:
    write(0)

while a > 0:
    a -= 1

texto = "ok"
write(texto)
