# Prueba 2: Operaciones aritméticas básicas

int a
int b
int resultado

a = 15
b = 4

resultado = a + b
write(resultado)

resultado = a - b
write(resultado)

resultado = a * b
write(resultado)

resultado = a / b
write(resultado)

resultado = a % b
write(resultado)

resultado = a ** 2
write(resultado)
